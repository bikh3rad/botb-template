# Copy to .env and adjust as needed:  cp .env.example .env && docker compose up -d --build
# Every value has a safe default in docker-compose.yml, so an empty .env still works.

# Public gateway port (host side). The gateway is the only published service.
GATEWAY_PORT=8080

# --- Postgres (infra/compose/datasource/postgresql.yaml) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# --- Shared admin JWT secret ---
# adminauth SIGNS admin bearer tokens with this HMAC secret; the gateway AND
# every service VERIFY with it (defense in depth). Use a long random value in
# production.
JWT_SECRET=dev-insecure-change-me

# --- First superadmin bootstrap (adminauth) ---
# On first boot, if no superadmin exists, adminauth creates one from these
# (idempotent). Change the password and rotate after first login; blank the
# email/password to skip and bootstrap manually instead.
ADMIN_BOOTSTRAP_NAME=Superadmin
ADMIN_BOOTSTRAP_EMAIL=admin@botb.local
ADMIN_BOOTSTRAP_PASSWORD=change-me-now

# --- MinIO / S3 (infra/compose/datasource/minio.yaml) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Bucket created on first run for the media service.
MEDIA_BUCKET=botb-media
