# --- Backend (Go gateway) wiring ---------------------------------------------

# Browser-facing gateway base URL. Baked into client bundles (NEXT_PUBLIC_*),
# and also used as the server-side fallback when API_BASE_URL_INTERNAL is unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Server-side gateway base URL (compose network). Used by Server Components and
# the admin auth route handlers; falls back to NEXT_PUBLIC_API_BASE_URL if unset.
API_BASE_URL_INTERNAL=http://gateway:8080

# Media is served SAME-ORIGIN at /media (proxied to MinIO by the Next rewrite),
# so object URLs follow whatever server IP/host the site is opened on. Leave as
# /media for the default proxy; set a full URL only to point the browser
# straight at a public MinIO/CDN host. MEDIA_UPSTREAM_URL is the internal MinIO
# address the proxy forwards to.
NEXT_PUBLIC_MEDIA_BASE_URL=/media
MEDIA_UPSTREAM_URL=http://minio:9000

# Shared HMAC secret for admin JWTs. adminauth SIGNS tokens with it; the gateway
# and every service VERIFY with it. Use a long random value in production.
# NOTE: the FRONTEND no longer receives this secret — admins log in through the
# adminauth service and tokens live in HttpOnly cookies, never in the browser.
JWT_SECRET=dev-insecure-change-me

# --- First superadmin bootstrap (adminauth) ----------------------------------
# On first boot, if NO superadmin exists yet, adminauth creates one from these.
# Idempotent: it never overwrites an existing account. CHANGE THE PASSWORD and
# rotate it after first login. Leave EMAIL/PASSWORD blank to skip bootstrap and
# create the first superadmin manually instead.
ADMIN_BOOTSTRAP_NAME=Superadmin
ADMIN_BOOTSTRAP_EMAIL=admin@botb.local
ADMIN_BOOTSTRAP_PASSWORD=change-me-now

# --- Published host ports ----------------------------------------------------
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- Postgres (backend/infra/compose/datasource/postgresql.yaml) -------------
POSTGRES_PORT=5432
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# --- MinIO / S3 (backend/infra/compose/datasource/minio.yaml) ----------------
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Bucket created (public-read) on first run for the media service + seeder.
MEDIA_BUCKET=botb-media
