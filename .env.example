# Shared secret guarding admin-only routes (e.g. POST /admin/api/media).
# Requests must send this value as `Authorization: Bearer <token>` or the
# `admin_token` cookie. If unset, all admin routes fail closed (reject).
ADMIN_TOKEN=

# --- Backend (Go gateway) wiring ---------------------------------------------

# Browser-facing gateway base URL. Baked into client bundles (NEXT_PUBLIC_*),
# and also used as the server-side fallback when API_BASE_URL_INTERNAL is unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Server-side gateway base URL (compose network). Used by Server Components and
# route handlers; falls back to NEXT_PUBLIC_API_BASE_URL when unset.
API_BASE_URL_INTERNAL=http://gateway:8080

# Browser-facing MinIO base URL. Media object URLs are built as
# ${NEXT_PUBLIC_MEDIA_BASE_URL}/${bucket}/${object_key} (public-read bucket).
NEXT_PUBLIC_MEDIA_BASE_URL=http://localhost:9000

# Server-only HMAC secret used to mint a short-lived admin bearer token so
# Server Components can read the admin draws/users lists for the winners feed.
# MUST match the gateway's JWT secret. NEVER expose this as NEXT_PUBLIC_*.
JWT_SECRET=dev-insecure-change-me

# --- Published host ports ----------------------------------------------------
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- Postgres (backend/infra/compose/datasource/postgresql.yaml) -------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db

# --- MinIO / S3 (backend/infra/compose/datasource/minio.yaml) ----------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# Bucket created (public-read) on first run for the media service + seeder.
MEDIA_BUCKET=botb-media
